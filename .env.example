# Copy this file to .env and fill in your real values. Never commit .env.

# Google Gemini API — free tier available at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gmail SMTP + IMAP (sending applications + checking replies)
# This must be an App Password, NOT your normal Gmail password.
# Get it: Google Account -> Security -> 2-Step Verification -> App Passwords
# Also enable IMAP: Gmail Settings -> Forwarding and POP/IMAP -> Enable IMAP
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Adzuna — free signup at https://developer.adzuna.com/
# Covers UK, US, Germany, Austria, Australia
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble — free signup at https://jooble.org/api/about
# Broader international coverage, better for UAE/Saudi Arabia
JOOBLE_API_KEY=
